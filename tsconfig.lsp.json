{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["bin/**/*.mjs", "src/**/*.mjs", "test/**/*.mjs"]
}
