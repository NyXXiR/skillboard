#!/usr/bin/env sh
set -eu

SKILLBOARD_BIN=${SKILLBOARD_BIN:-'node bin/skillboard.mjs'}
SKILLBOARD_CONFIG=${SKILLBOARD_CONFIG:-'examples/multi-source.config.yaml'}
SKILLBOARD_SKILLS=${SKILLBOARD_SKILLS:-'examples/multi-source-skills'}
SKILLBOARD_WORKFLOW=${SKILLBOARD_WORKFLOW:-'codex-night-workflow'}

if [ "${SKILLBOARD_SKILL_ID:-}" != "" ]; then
  skill_id="$SKILLBOARD_SKILL_ID"
elif [ "${1:-}" != "" ]; then
  skill_id="$1"
else
  echo "SKILLBOARD_SKILL_ID or first argument is required" >&2
  exit 64
fi

exec "$SKILLBOARD_BIN" guard use "$skill_id" --workflow "$SKILLBOARD_WORKFLOW" --config "$SKILLBOARD_CONFIG" --skills "$SKILLBOARD_SKILLS"

