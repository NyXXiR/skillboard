  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0"
  }
}
