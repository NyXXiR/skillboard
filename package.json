{
  "name": "agent-skillboard",
  "version": "0.1.0",
  "description": "Workflow-scoped control plane for AI agent skills.",
  "type": "module",
  "files": [
    "bin",
    "src",
    "docs",
    "examples",
    "profiles",
    "README.md",
    "LICENSE",
    "tsconfig.lsp.json"
  ],
  "bin": {
    "skillboard": "bin/skillboard.mjs"
  },
